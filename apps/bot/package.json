{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run --hot src/index.ts",
		"start": "bun run dist/index.mjs"
	},
	"dependencies": {
		"@chat-adapter/github": "^4.20.2",
		"@chat-adapter/state-redis": "^4.20.2",
		"@dotato/db": "workspace:*",
		"@dotato/env": "workspace:*",
		"chat": "^4.20.2",
		"dotenv": "catalog:",
		"hono": "^4.8.2",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@dotato/config": "workspace:*",
		"@types/bun": "catalog:",
		"tsdown": "^0.16.5",
		"typescript": "^5"
	}
}
